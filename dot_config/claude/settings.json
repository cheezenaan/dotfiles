{
  "model": "default",
  "permissions": {
    "defaultMode": "plan",
    "allow": [],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf /)",
      "Bash(git push origin main:*)",
      "Bash(git rebase:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "includeCoAuthoredBy": false,
  "cleanupPeriodDays": 90,
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.config/claude/statusline.py"
  }
}
